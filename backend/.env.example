# Patroller Backend Configuration

# HTTP server port
PORT=3099

# SQLite database file path
DB_PATH=./data/patroller.db

# Enable Tailscale identity verification (set to "true" for production with Tailscale)
TAILSCALE_AUTH=false

# Logging level: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# CORS allowed origins (comma-separated, or "*" for all)
CORS_ORIGINS=*
